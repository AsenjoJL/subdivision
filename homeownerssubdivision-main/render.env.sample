# Copy these into Render environment variables (do not commit real secrets)
ASPNETCORE_ENVIRONMENT=Production
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/firebase.json
# Recommended on Render: mount a disk at /var/data and persist DataProtection keys there
DATA_PROTECTION_KEYS_DIR=/var/data/dp-keys

FirebaseAuthentication__WebApiKey=YOUR_FIREBASE_WEB_API_KEY

SupabaseStorage__ProjectUrl=https://your-project.supabase.co
SupabaseStorage__ServiceRoleKey=YOUR_SUPABASE_SERVICE_ROLE_KEY
SupabaseStorage__ApiKey=YOUR_SUPABASE_ANON_API_KEY
SupabaseStorage__BucketName=profile-images
SupabaseStorage__ObjectPrefix=homeowners
SupabaseStorage__UseUpsert=true

Sms__Enabled=true
Sms__BaseUrl=https://www.iprogsms.com/api/v1/sms_messages
Sms__ApiToken=YOUR_IPROGSMS_API_TOKEN
Sms__SmsProvider=0
Sms__DefaultCountryCode=+63

Email__Enabled=true
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__Username=you@example.com
Email__Password=APP_PASSWORD_OR_SMTP_PASSWORD
Email__FromAddress=you@example.com
Email__FromName=RestNestHome
Email__EnableSsl=true

# Leave DB_CONNECTION_STRING unset unless you migrate to SQL Server
# DB_CONNECTION_STRING=
