@model HOMEOWNER.Models.ViewModels.ReservationHistoryViewModel
@{
    var isEmbedded = Model.IsEmbedded;
}

<div class="container" id="reservationHistoryModule">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="@(isEmbedded ? "#" : Url.Action("Index", "Reservation"))"
           class="btn btn-outline-secondary reservation-back-link"
           data-reservation-url="@Url.Action("Index", "Reservation")">
            <i class="fas fa-arrow-left"></i> Back to reservations
        </a>
    </div>

    <h3><i class="fas fa-history"></i> Reservation History</h3>

    @if (Model.Reservations.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Facility</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Purpose</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reservations)
                {
                    <tr>
                        <td>@r.Facility?.FacilityName</td>
                        <td>@r.ReservationDate.ToShortDateString()</td>
                        <td>@r.StartTime - @r.EndTime</td>
                        <td>@r.Purpose</td>
                        <td>
                            <span class="badge badge-@(r.Status == "Expired" ? "secondary" : r.Status == "Canceled" ? "danger" : "success")">
                                @r.Status
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No reservation history found.</p>
    }
</div>

<script>
    (() => {
        const root = document.getElementById('reservationHistoryModule');
        if (!root || typeof window.loadContent !== 'function') {
            return;
        }

        const backLink = root.querySelector('.reservation-back-link');
        backLink?.addEventListener('click', event => {
            event.preventDefault();
            window.loadContent(backLink.dataset.reservationUrl);
        });
    })();
</script>
