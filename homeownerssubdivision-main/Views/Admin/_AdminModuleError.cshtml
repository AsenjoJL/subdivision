@model string

<div class="glass-card section-card admin-settings-card">
    <div class="admin-settings-header">
        <div>
            <p class="admin-settings-eyebrow">Admin settings</p>
            <h2 class="admin-settings-title">Unable to load module</h2>
        </div>
    </div>
    <div class="admin-settings-body">
        <div class="admin-settings-alert admin-settings-alert--error">
            <i class="fas fa-circle-exclamation"></i>
            <span>@Model</span>
        </div>
    </div>
</div>
