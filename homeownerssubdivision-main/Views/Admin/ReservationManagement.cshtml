            <div class="reservation-modal-body">
                <div class="reservation-details-grid">
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Facility</div><div class="reservation-detail-value" id="reservationDetailFacility">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Homeowner</div><div class="reservation-detail-value" id="reservationDetailHomeowner">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Date</div><div class="reservation-detail-value" id="reservationDetailDate">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Time window</div><div class="reservation-detail-value" id="reservationDetailTime">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Status</div><div class="reservation-detail-value" id="reservationDetailStatus">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Created</div><div class="reservation-detail-value" id="reservationDetailCreated">-</div></div>
                    <div class="reservation-detail-item" style="grid-column: 1 / -1;">
                        <div class="reservation-detail-label">Purpose</div>
                        <div class="reservation-detail-value" id="reservationDetailPurpose">-</div>
                    </div>
