@model HOMEOWNER.Models.ViewModels.ReservationManagementViewModel

<style>
    :root {
        --reservation-primary: #4361ee;
        --reservation-primary-hover: #3651d4;
        --reservation-text: #18263d;
        --reservation-muted: #64748b;
        --reservation-line: rgba(18, 35, 60, 0.08);
        --reservation-surface: #ffffff;
        --reservation-surface-soft: #f8fbff;
        --reservation-success: #157f61;
        --reservation-warning: #a96a00;
        --reservation-danger: #b42318;
        --reservation-neutral: #5b6b81;
    }

    .reservation-module {
        color: var(--reservation-text);
    }

    .reservation-token-form {
        display: none;
    }

    .reservation-stack {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .reservation-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
    }

    .reservation-summary-card {
        background: var(--reservation-surface);
        border: 1px solid var(--reservation-line);
        border-radius: 18px;
        padding: 1.2rem 1.25rem;
        box-shadow: 0 10px 26px rgba(18, 35, 60, 0.05);
    }

    .reservation-summary-label {
        margin: 0;
        font-size: 0.84rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--reservation-muted);
    }

    .reservation-summary-value {
        margin: 0.45rem 0 0;
        font-size: 2rem;
        font-weight: 800;
        color: var(--reservation-text);
        letter-spacing: -0.04em;
    }

    .reservation-summary-caption {
        margin-top: 0.35rem;
        color: var(--reservation-muted);
        font-size: 0.88rem;
    }

    .reservation-panel {
        background: var(--reservation-surface);
        border: 1px solid var(--reservation-line);
        border-radius: 22px;
        box-shadow: 0 14px 32px rgba(18, 35, 60, 0.06);
        overflow: hidden;
    }

    .reservation-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding: 1.35rem 1.5rem 1rem;
        border-bottom: 1px solid var(--reservation-line);
    }

    .reservation-panel-title {
        margin: 0;
        font-size: 1.45rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--reservation-text);
    }

    .reservation-panel-title i {
        color: var(--reservation-primary);
    }

    .reservation-panel-caption {
        margin: 0.4rem 0 0;
        color: var(--reservation-muted);
        font-size: 0.92rem;
    }

    .reservation-panel-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        align-items: center;
    }

    .reservation-button {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        height: 42px;
        padding: 0 1rem;
        border-radius: 10px;
        border: 1px solid transparent;
        background: var(--reservation-primary);
        color: #ffffff;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
    }

    .reservation-button:hover {
        background: var(--reservation-primary-hover);
        transform: translateY(-1px);
        box-shadow: 0 10px 22px rgba(67, 97, 238, 0.18);
    }

    .reservation-button-secondary {
        background: #ffffff;
        color: var(--reservation-text);
        border-color: rgba(18, 35, 60, 0.14);
    }

    .reservation-button-secondary:hover {
        background: #f5f8ff;
        box-shadow: none;
    }

    .reservation-panel-body {
        padding: 1.25rem 1.5rem 1.5rem;
    }

    .reservation-section-alert {
        margin-bottom: 1rem;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        font-weight: 600;
        position: relative;
    }

    .reservation-section-alert.is-success {
        background: rgba(21, 127, 97, 0.08);
        color: var(--reservation-success);
        border: 1px solid rgba(21, 127, 97, 0.16);
    }

    .reservation-section-alert.is-error {
        background: rgba(180, 35, 24, 0.08);
        color: var(--reservation-danger);
        border: 1px solid rgba(180, 35, 24, 0.16);
    }

    .reservation-hidden {
        display: none !important;
    }

    .reservation-table-shell {
        overflow-x: auto;
    }

    .reservation-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .reservation-table th {
        background: var(--reservation-primary);
        color: #ffffff;
        font-weight: 700;
        padding: 0.9rem 1rem;
        text-align: left;
    }

    .reservation-table th:first-child {
        border-top-left-radius: 12px;
    }

    .reservation-table th:last-child {
        border-top-right-radius: 12px;
    }

    .reservation-table td {
        padding: 0.95rem 1rem;
        border-bottom: 1px solid var(--reservation-line);
        color: #45556f;
        vertical-align: middle;
        font-weight: 500;
    }

    .reservation-table tbody tr:hover {
        background: rgba(67, 97, 238, 0.04);
    }

    .reservation-action-row {
        display: flex;
        gap: 0.45rem;
        align-items: center;
    }

    .reservation-icon-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 1px solid rgba(18, 35, 60, 0.08);
        background: #ffffff;
        color: var(--reservation-primary);
        cursor: pointer;
        transition: transform 0.18s ease, background-color 0.18s ease;
    }

    .reservation-icon-button:hover {
        background: #eef3ff;
        transform: translateY(-1px);
    }

    .reservation-icon-button.is-success {
        color: var(--reservation-success);
    }

    .reservation-icon-button.is-success:hover {
        background: rgba(21, 127, 97, 0.08);
    }

    .reservation-icon-button.is-danger {
        color: var(--reservation-danger);
    }

    .reservation-icon-button.is-danger:hover {
        background: rgba(180, 35, 24, 0.08);
    }

    .reservation-status-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 88px;
        padding: 0.42rem 0.7rem;
        border-radius: 999px;
        font-size: 0.83rem;
        font-weight: 700;
        background: rgba(91, 107, 129, 0.08);
        color: var(--reservation-neutral);
    }

    .reservation-status-chip.is-available,
    .reservation-status-chip.is-approved {
        background: rgba(21, 127, 97, 0.1);
        color: var(--reservation-success);
    }

    .reservation-status-chip.is-unavailable,
    .reservation-status-chip.is-rejected {
        background: rgba(180, 35, 24, 0.1);
        color: var(--reservation-danger);
    }

    .reservation-status-chip.is-pending {
        background: rgba(169, 106, 0, 0.12);
        color: var(--reservation-warning);
    }

    .reservation-status-chip.is-cancelled {
        background: rgba(91, 107, 129, 0.1);
        color: var(--reservation-neutral);
    }

    .reservation-facility-thumb {
        width: 78px;
        height: 54px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid rgba(18, 35, 60, 0.08);
    }

    .reservation-muted-text {
        color: var(--reservation-muted);
        font-size: 0.88rem;
    }

    .reservation-empty-cell {
        text-align: center;
        color: var(--reservation-muted);
        padding: 1.4rem 0;
    }

    .reservation-modal {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(10, 17, 30, 0.45);
        backdrop-filter: blur(5px);
        z-index: 1200;
    }

    .reservation-modal.is-open {
        display: flex;
    }

    .reservation-modal-dialog {
        width: min(100%, 640px);
        max-height: calc(100vh - 48px);
    }

    .reservation-modal-panel {
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        max-height: min(88vh, 760px);
        box-shadow: 0 30px 80px rgba(4, 10, 20, 0.3);
    }

    .reservation-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.2rem 1.4rem;
        background: var(--reservation-primary);
        color: #ffffff;
    }

    .reservation-modal-title {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .reservation-modal-close {
        border: none;
        background: transparent;
        color: #ffffff;
        font-size: 1.1rem;
        cursor: pointer;
    }

    .reservation-modal-body {
        padding: 1.35rem 1.4rem;
        overflow-y: auto;
    }

    .reservation-modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1rem 1.4rem 1.2rem;
        border-top: 1px solid var(--reservation-line);
        background: #ffffff;
    }

    .reservation-alert {
        margin-bottom: 1rem;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        font-weight: 600;
        position: relative;
    }

    .reservation-alert.is-success {
        background: rgba(21, 127, 97, 0.08);
        color: var(--reservation-success);
        border: 1px solid rgba(21, 127, 97, 0.16);
    }

    .reservation-alert.is-error {
        background: rgba(180, 35, 24, 0.08);
        color: var(--reservation-danger);
        border: 1px solid rgba(180, 35, 24, 0.16);
    }

    .reservation-form-row {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .reservation-form-group {
        margin-bottom: 1rem;
    }

    .reservation-form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.4rem;
        font-weight: 700;
        color: var(--reservation-text);
    }

    .reservation-form-label i {
        color: var(--reservation-primary);
    }

    .reservation-form-control {
        width: 100%;
        min-height: 44px;
        padding: 10px 12px;
        border-radius: 10px;
        border: 1px solid rgba(18, 35, 60, 0.12);
        color: var(--reservation-text);
        background: #ffffff;
        font-size: 0.95rem;
        transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .reservation-form-control:focus {
        border-color: var(--reservation-primary);
        box-shadow: 0 0 0 0.2rem rgba(67, 97, 238, 0.12);
        outline: none;
    }

    .reservation-invalid {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.12) !important;
    }

    .reservation-field-error {
        margin-top: 0.35rem;
        color: var(--reservation-danger);
        font-size: 0.82rem;
        line-height: 1.3;
    }

    .reservation-details-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .reservation-detail-item {
        padding: 0.9rem 1rem;
        border-radius: 12px;
        background: var(--reservation-surface-soft);
        border: 1px solid var(--reservation-line);
    }

    .reservation-detail-label {
        color: var(--reservation-muted);
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .reservation-detail-value {
        margin-top: 0.35rem;
        color: var(--reservation-text);
        font-weight: 700;
        word-break: break-word;
    }

    .reservation-detail-image {
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        border-radius: 14px;
        border: 1px solid var(--reservation-line);
        background: var(--reservation-surface-soft);
    }

    @@media (max-width: 1100px) {
        .reservation-summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .reservation-panel-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .reservation-panel-actions {
            width: 100%;
        }

        .reservation-form-row,
        .reservation-details-grid,
        .reservation-summary-grid {
            grid-template-columns: 1fr;
        }

        .reservation-modal {
            align-items: flex-start;
            padding: 16px;
            overflow-y: auto;
        }

        .reservation-modal-dialog {
            width: 100%;
            max-height: calc(100vh - 32px);
            margin: 18px 0;
        }
    }
</style>

<div
    id="reservationManagementModule"
    class="reservation-module"
    data-summary-url="@Url.Action("ReservationManagementSummary", "Admin")"
    data-facilities-url="@Url.Action("LoadFacilitiesList", "Admin")"
    data-facilities-lookup-url="@Url.Action("GetFacilitiesLookup", "Admin")"
    data-reservations-url="@Url.Action("LoadReservationsList", "Admin")"
    data-add-facility-url="@Url.Action("AddFacility", "Admin")"
    data-edit-facility-url="@Url.Action("EditFacility", "Admin")"
    data-delete-facility-url="@Url.Action("DeleteFacility", "Admin")"
    data-approve-url="@Url.Action("ApproveReservation", "Admin")"
    data-reject-url="@Url.Action("RejectReservation", "Admin")"
    data-report-url="@Url.Action("GenerateReservationReport", "Admin")">

    <form id="reservationManagementTokenForm" class="reservation-token-form">
        @Html.AntiForgeryToken()
    </form>

    <div id="reservationSectionAlert" class="reservation-section-alert @(Model.HasLoadError ? "is-error" : "reservation-hidden")">
        @(Model.HasLoadError ? Model.LoadErrorMessage : string.Empty)
    </div>

    <div class="reservation-stack">
        <section class="reservation-summary-grid">
            <article class="reservation-summary-card">
                <p class="reservation-summary-label">Total reservations</p>
                <p class="reservation-summary-value" id="reservationSummaryTotal">@Model.TotalReservations</p>
                <div class="reservation-summary-caption">Across all facilities</div>
            </article>
            <article class="reservation-summary-card">
                <p class="reservation-summary-label">Approval rate</p>
                <p class="reservation-summary-value" id="reservationSummaryApproval">@Model.ApprovalRate%</p>
                <div class="reservation-summary-caption">
                    Approved: <span id="reservationSummaryApproved">@Model.ApprovedCount</span> |
                    Pending: <span id="reservationSummaryPending">@Model.PendingCount</span>
                </div>
            </article>
            <article class="reservation-summary-card">
                <p class="reservation-summary-label">Most booked facility</p>
                <p class="reservation-summary-value" id="reservationSummaryPopular">@Model.PopularFacility</p>
                <div class="reservation-summary-caption">
                    <span id="reservationSummaryPopularCount">@Model.PopularFacilityCount</span> bookings
                </div>
            </article>
            <article class="reservation-summary-card">
                <p class="reservation-summary-label">Peak reservation day</p>
                <p class="reservation-summary-value" id="reservationSummaryPeak">@Model.PeakDay</p>
                <div class="reservation-summary-caption">
                    <span id="reservationSummaryPeakCount">@Model.PeakDayCount</span> bookings
                </div>
            </article>
        </section>

        <section class="reservation-panel">
            <div class="reservation-panel-header">
                <div>
                    <h2 class="reservation-panel-title"><i class="fas fa-warehouse"></i>Facility management</h2>
                    <p class="reservation-panel-caption">Add, review, edit, and retire community facilities from one place.</p>
                </div>
                <div class="reservation-panel-actions">
                    <button type="button" class="reservation-button" id="openAddFacilityModal">
                        <i class="fas fa-plus"></i>
                        <span>Add facility</span>
                    </button>
                </div>
            </div>
            <div class="reservation-panel-body">
                <div class="reservation-table-shell">
                    <table class="reservation-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Image</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="facilityTableBody">
                            @await Html.PartialAsync("_FacilityTableRows", Model.Facilities)
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="reservation-panel">
            <div class="reservation-panel-header">
                <div>
                    <h2 class="reservation-panel-title"><i class="fas fa-calendar-check"></i>Reservation operations</h2>
                    <p class="reservation-panel-caption">Monitor live bookings, inspect details, handle exceptions, and export reports.</p>
                </div>
                <div class="reservation-panel-actions">
                    <a href="@Url.Action("ViewExpiredHistory", "Reservation")" class="reservation-button reservation-button-secondary">
                        <i class="fas fa-clock-rotate-left"></i>
                        <span>View expired</span>
                    </a>
                    <button type="button" class="reservation-button" id="openReportModal">
                        <i class="fas fa-file-arrow-down"></i>
                        <span>Generate report</span>
                    </button>
                </div>
            </div>
            <div class="reservation-panel-body">
                <div class="reservation-table-shell">
                    <table class="reservation-table">
                        <thead>
                            <tr>
                                <th>Facility</th>
                                <th>Homeowner</th>
                                <th>Date</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Purpose</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="reservationTableBody">
                            @await Html.PartialAsync("_ReservationTableRows", Model.ActiveReservations)
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </div>
</div>

<div class="reservation-modal" id="addFacilityModal" aria-hidden="true" role="dialog">
    <div class="reservation-modal-dialog">
        <div class="reservation-modal-panel">
            <div class="reservation-modal-header">
                <h3 class="reservation-modal-title"><i class="fas fa-plus"></i>Add facility</h3>
                <button type="button" class="reservation-modal-close" data-reservation-close="addFacilityModal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="reservation-modal-body">
                <div id="addFacilityAlert" class="reservation-alert reservation-hidden"></div>
                <form id="addFacilityForm" enctype="multipart/form-data">
                    <div class="reservation-form-row">
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-building"></i> Facility name</label>
                            <input type="text" class="reservation-form-control" name="FacilityName" data-facility-input="add:FacilityName" required>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="add:FacilityName"></div>
                        </div>
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-users"></i> Capacity</label>
                            <input type="number" class="reservation-form-control" name="Capacity" data-facility-input="add:Capacity" min="1" required>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="add:Capacity"></div>
                        </div>
                    </div>
                    <div class="reservation-form-group">
                        <label class="reservation-form-label"><i class="fas fa-align-left"></i> Description</label>
                        <textarea class="reservation-form-control" name="Description" data-facility-input="add:Description" rows="3" required></textarea>
                        <div class="reservation-field-error reservation-hidden" data-facility-error="add:Description"></div>
                    </div>
                    <div class="reservation-form-row">
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-toggle-on"></i> Status</label>
                            <select class="reservation-form-control" name="AvailabilityStatus" data-facility-input="add:AvailabilityStatus" required>
                                <option value="Available">Available</option>
                                <option value="Unavailable">Unavailable</option>
                            </select>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="add:AvailabilityStatus"></div>
                        </div>
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-image"></i> Images</label>
                            <input type="file" class="reservation-form-control" name="ImageFiles" data-facility-input="add:ImageFiles" accept="image/*" multiple>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="add:ImageFiles"></div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="reservation-modal-footer">
                <button type="button" class="reservation-button reservation-button-secondary" data-reservation-close="addFacilityModal">Cancel</button>
                <button type="button" class="reservation-button" id="submitAddFacility">
                    <i class="fas fa-save"></i>
                    <span>Save facility</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="reservation-modal" id="editFacilityModal" aria-hidden="true" role="dialog">
    <div class="reservation-modal-dialog">
        <div class="reservation-modal-panel">
            <div class="reservation-modal-header">
                <h3 class="reservation-modal-title"><i class="fas fa-pen-to-square"></i>Edit facility</h3>
                <button type="button" class="reservation-modal-close" data-reservation-close="editFacilityModal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="reservation-modal-body">
                <div id="editFacilityAlert" class="reservation-alert reservation-hidden"></div>
                <form id="editFacilityForm" enctype="multipart/form-data">
                    <input type="hidden" name="FacilityID" data-facility-input="edit:FacilityID">
                    <input type="hidden" name="ExistingImageUrl" data-facility-input="edit:ExistingImageUrl">
                    <div class="reservation-form-row">
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-building"></i> Facility name</label>
                            <input type="text" class="reservation-form-control" name="FacilityName" data-facility-input="edit:FacilityName" required>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="edit:FacilityName"></div>
                        </div>
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-users"></i> Capacity</label>
                            <input type="number" class="reservation-form-control" name="Capacity" data-facility-input="edit:Capacity" min="1" required>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="edit:Capacity"></div>
                        </div>
                    </div>
                    <div class="reservation-form-group">
                        <label class="reservation-form-label"><i class="fas fa-align-left"></i> Description</label>
                        <textarea class="reservation-form-control" name="Description" data-facility-input="edit:Description" rows="3" required></textarea>
                        <div class="reservation-field-error reservation-hidden" data-facility-error="edit:Description"></div>
                    </div>
                    <div class="reservation-form-row">
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-toggle-on"></i> Status</label>
                            <select class="reservation-form-control" name="AvailabilityStatus" data-facility-input="edit:AvailabilityStatus" required>
                                <option value="Available">Available</option>
                                <option value="Unavailable">Unavailable</option>
                            </select>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="edit:AvailabilityStatus"></div>
                        </div>
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-image"></i> Replace images</label>
                            <input type="file" class="reservation-form-control" name="ImageFiles" data-facility-input="edit:ImageFiles" accept="image/*" multiple>
                            <div class="reservation-field-error reservation-hidden" data-facility-error="edit:ImageFiles"></div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="reservation-modal-footer">
                <button type="button" class="reservation-button reservation-button-secondary" data-reservation-close="editFacilityModal">Cancel</button>
                <button type="button" class="reservation-button" id="submitEditFacility">
                    <i class="fas fa-save"></i>
                    <span>Update facility</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="reservation-modal" id="reservationDetailsModal" aria-hidden="true" role="dialog">
    <div class="reservation-modal-dialog">
        <div class="reservation-modal-panel">
            <div class="reservation-modal-header">
                <h3 class="reservation-modal-title"><i class="fas fa-eye"></i>Reservation details</h3>
                <button type="button" class="reservation-modal-close" data-reservation-close="reservationDetailsModal" aria-label="Close">
                    <i class="fas fa-times"></i>
