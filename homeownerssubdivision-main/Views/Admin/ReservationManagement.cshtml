            <div class="reservation-modal-footer">
                <button type="button" class="reservation-button reservation-button-secondary" data-reservation-close="reservationDetailsModal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="reservation-modal" id="facilityDetailsModal" aria-hidden="true" role="dialog">
    <div class="reservation-modal-dialog">
        <div class="reservation-modal-panel">
            <div class="reservation-modal-header">
                <h3 class="reservation-modal-title"><i class="fas fa-eye"></i>Facility details</h3>
                <button type="button" class="reservation-modal-close" data-reservation-close="facilityDetailsModal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="reservation-modal-body">
                <div class="reservation-details-grid">
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Facility</div><div class="reservation-detail-value" id="facilityDetailName">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Status</div><div class="reservation-detail-value" id="facilityDetailStatus">-</div></div>
                    <div class="reservation-detail-item"><div class="reservation-detail-label">Capacity</div><div class="reservation-detail-value" id="facilityDetailCapacity">-</div></div>
                    <div class="reservation-detail-item" style="grid-column: 1 / -1;">
                        <div class="reservation-detail-label">Description</div>
