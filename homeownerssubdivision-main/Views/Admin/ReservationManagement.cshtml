<div class="reservation-modal" id="reportModal" aria-hidden="true" role="dialog">
    <div class="reservation-modal-dialog">
        <div class="reservation-modal-panel">
            <div class="reservation-modal-header">
                <h3 class="reservation-modal-title"><i class="fas fa-file-arrow-down"></i>Generate reservation report</h3>
                <button type="button" class="reservation-modal-close" data-reservation-close="reportModal" aria-label="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="reservation-modal-body">
                <form id="reportForm">
                    <div class="reservation-form-group">
                        <label class="reservation-form-label"><i class="fas fa-layer-group"></i> Report type</label>
                        <select class="reservation-form-control" name="reportType">
                            <option value="summary">Summary report</option>
                            <option value="detailed">Detailed report</option>
                            <option value="facility">Facility usage report</option>
                        </select>
                    </div>
                    <div class="reservation-form-row">
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-calendar-day"></i> Start date</label>
                            <input type="date" class="reservation-form-control" name="startDate">
                        </div>
                        <div class="reservation-form-group">
                            <label class="reservation-form-label"><i class="fas fa-calendar-day"></i> End date</label>
                            <input type="date" class="reservation-form-control" name="endDate">
                        </div>
                    </div>
                    <div class="reservation-form-group">
                        <label class="reservation-form-label"><i class="fas fa-warehouse"></i> Facility</label>
                        <select class="reservation-form-control" name="facilityId" id="reportFacilitySelect">
                            <option value="">All facilities</option>
                            @foreach (var facility in Model.Facilities)
                            {
                                <option value="@facility.FacilityID">@facility.FacilityName</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
            <div class="reservation-modal-footer">
                <button type="button" class="reservation-button reservation-button-secondary" data-reservation-close="reportModal">Cancel</button>
                <button type="button" class="reservation-button" id="generateReservationReport">
                    <i class="fas fa-download"></i>
                    <span>Download CSV</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        if (window.__reservationManagementCleanup) {
            window.__reservationManagementCleanup();
        }

        const moduleRoot = document.getElementById('reservationManagementModule');
        if (!moduleRoot) {
            return;
        }

        const moduleContainer = moduleRoot.parentElement || document;
        const token = document.querySelector('#reservationManagementTokenForm input[name="__RequestVerificationToken"]')?.value || '';
        const facilityTableBody = document.getElementById('facilityTableBody');
        const reservationTableBody = document.getElementById('reservationTableBody');
        const sectionAlert = document.getElementById('reservationSectionAlert');

        const addFacilityModal = moduleContainer.querySelector('#addFacilityModal');
        const editFacilityModal = moduleContainer.querySelector('#editFacilityModal');
        const detailsModal = moduleContainer.querySelector('#reservationDetailsModal');
        const facilityDetailsModal = moduleContainer.querySelector('#facilityDetailsModal');
        const reportModal = moduleContainer.querySelector('#reportModal');

        const addFacilityForm = document.getElementById('addFacilityForm');
        const editFacilityForm = document.getElementById('editFacilityForm');
        const reportForm = document.getElementById('reportForm');

        const addFacilityAlert = document.getElementById('addFacilityAlert');
        const editFacilityAlert = document.getElementById('editFacilityAlert');

        const openAddFacilityButton = document.getElementById('openAddFacilityModal');
        const openReportButton = document.getElementById('openReportModal');
        const submitAddFacilityButton = document.getElementById('submitAddFacility');
        const submitEditFacilityButton = document.getElementById('submitEditFacility');
        const generateReportButton = document.getElementById('generateReservationReport');
        const reportFacilitySelect = document.getElementById('reportFacilitySelect');

        if (!facilityTableBody || !reservationTableBody || !addFacilityModal || !editFacilityModal || !detailsModal || !facilityDetailsModal || !reportModal || !addFacilityForm || !editFacilityForm || !reportForm || !openAddFacilityButton || !openReportButton || !submitAddFacilityButton || !submitEditFacilityButton || !generateReportButton || !reportFacilitySelect) {
            return;
        }

        const reservationModals = [addFacilityModal, editFacilityModal, detailsModal, facilityDetailsModal, reportModal];
        let sectionAlertTimer = null;

        reservationModals.forEach(function (modal) {
            Array.from(document.querySelectorAll('[id="' + modal.id + '"]'))
                .filter(function (candidate) { return candidate !== modal; })
                .forEach(function (staleModal) { staleModal.remove(); });

            if (modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
        });

        function showSectionAlert(type, message) {
            if (!sectionAlert) {
                return;
            }

            if (sectionAlertTimer) {
                clearTimeout(sectionAlertTimer);
                sectionAlertTimer = null;
            }

            sectionAlert.className = 'reservation-section-alert';
            sectionAlert.classList.add(type === 'success' ? 'is-success' : 'is-error');
            sectionAlert.textContent = message;
            sectionAlert.classList.remove('reservation-hidden');

            if (type === 'success') {
                sectionAlertTimer = setTimeout(function () {
                    clearSectionAlert();
                }, 3200);
            }
        }

        function clearSectionAlert() {
            if (!sectionAlert) {
                return;
            }

            if (sectionAlertTimer) {
                clearTimeout(sectionAlertTimer);
                sectionAlertTimer = null;
            }

            sectionAlert.className = 'reservation-section-alert reservation-hidden';
            sectionAlert.textContent = '';
        }

        function showModal(modal) {
            modal.classList.add('is-open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modal) {
            modal.classList.remove('is-open');
            modal.setAttribute('aria-hidden', 'true');
            const hasOpenModal = reservationModals.some(function (candidate) {
                return candidate.classList.contains('is-open');
            });
            document.body.style.overflow = hasOpenModal ? 'hidden' : '';
        }

        function clearFacilityFieldErrors(prefix) {
            document.querySelectorAll('[data-facility-error^="' + prefix + ':"]').forEach(function (element) {
                element.textContent = '';
                element.classList.add('reservation-hidden');
            });

            document.querySelectorAll('[data-facility-input^="' + prefix + ':"]').forEach(function (input) {
                input.classList.remove('reservation-invalid');
                input.removeAttribute('aria-invalid');
            });
        }

        function showFacilityFieldError(prefix, fieldName, message) {
            const input = document.querySelector('[data-facility-input="' + prefix + ':' + fieldName + '"]');
            const error = document.querySelector('[data-facility-error="' + prefix + ':' + fieldName + '"]');

            if (input) {
                input.classList.add('reservation-invalid');
                input.setAttribute('aria-invalid', 'true');
            }

            if (error) {
                error.textContent = message;
                error.classList.remove('reservation-hidden');
            }
        }

        function applyFacilityErrors(prefix, payload) {
            clearFacilityFieldErrors(prefix);

            if (!payload) {
                return;
            }

            if (payload.field && payload.message) {
                showFacilityFieldError(prefix, payload.field, payload.message);
                return;
            }

            if (payload.validationErrors && typeof payload.validationErrors === 'object') {
                Object.keys(payload.validationErrors).forEach(function (fieldName) {
                    const messages = payload.validationErrors[fieldName];
                    if (Array.isArray(messages) && messages.length > 0) {
                        showFacilityFieldError(prefix, fieldName, messages[0]);
                    }
                });
            }
        }

        function showModalAlert(alertElement, type, message) {
            if (!alertElement) {
                return;
            }

            alertElement.className = 'reservation-alert';
            alertElement.classList.add(type === 'success' ? 'is-success' : 'is-error');
            alertElement.textContent = message;
            alertElement.classList.remove('reservation-hidden');
        }

        function clearModalAlert(alertElement) {
            if (!alertElement) {
                return;
            }

            alertElement.className = 'reservation-alert reservation-hidden';
            alertElement.textContent = '';
        }

        async function fetchText(url) {
            const response = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin'
            });

            if (!response.ok) {
                throw new Error('Unable to load updated data.');
            }

            return response.text();
        }

        async function refreshFacilitiesTable() {
            facilityTableBody.innerHTML = await fetchText(moduleRoot.dataset.facilitiesUrl);
        }

        async function refreshReservationsTable() {
            reservationTableBody.innerHTML = await fetchText(moduleRoot.dataset.reservationsUrl);
        }

        async function refreshFacilityLookup() {
            const response = await fetch(moduleRoot.dataset.facilitiesLookupUrl, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin'
            });

            if (!response.ok) {
                throw new Error('Unable to refresh facility lookup.');
            }

            const facilities = await response.json();
            const existingValue = reportFacilitySelect.value;
            reportFacilitySelect.innerHTML = '<option value="">All facilities</option>';

            facilities.forEach(function (facility) {
                const option = document.createElement('option');
                option.value = facility.facilityID;
                option.textContent = facility.facilityName;
                reportFacilitySelect.appendChild(option);
            });

            reportFacilitySelect.value = existingValue;
        }

        async function refreshSummary() {
            const response = await fetch(moduleRoot.dataset.summaryUrl, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                credentials: 'same-origin'
            });

            if (!response.ok) {
                throw new Error('Unable to refresh reservation summary.');
            }

            const payload = await response.json();
            document.getElementById('reservationSummaryTotal').textContent = payload.totalReservations ?? 0;
            document.getElementById('reservationSummaryApproval').textContent = (payload.approvalRate ?? 0) + '%';
            document.getElementById('reservationSummaryApproved').textContent = payload.approvedCount ?? 0;
            document.getElementById('reservationSummaryPending').textContent = payload.pendingCount ?? 0;
            document.getElementById('reservationSummaryPopular').textContent = payload.popularFacility ?? 'No data';
            document.getElementById('reservationSummaryPopularCount').textContent = payload.popularFacilityCount ?? 0;
            document.getElementById('reservationSummaryPeak').textContent = payload.peakDay ?? 'No data';
            document.getElementById('reservationSummaryPeakCount').textContent = payload.peakDayCount ?? 0;
        }

        async function refreshReservationModule() {
            const results = await Promise.allSettled([
                refreshFacilitiesTable(),
                refreshReservationsTable(),
                refreshFacilityLookup(),
                refreshSummary()
            ]);

            const failed = results.find(function (result) {
                return result.status === 'rejected';
            });

            if (failed) {
                console.error(failed.reason);
                showSectionAlert('error', 'Some reservation data could not be refreshed. The section is showing the latest data it could load.');
            }
        }

        async function refreshFacilitiesModule() {
            await Promise.all([
                refreshFacilitiesTable(),
                refreshFacilityLookup()
            ]);
        }

        function buildFormBody(additionalFields) {
            const params = new URLSearchParams(additionalFields);
            params.append('__RequestVerificationToken', token);
            return params.toString();
        }

        function populateEditFacilityForm(facility) {
            editFacilityForm.querySelector('[data-facility-input="edit:FacilityID"]').value = facility.facilityID || '';
            editFacilityForm.querySelector('[data-facility-input="edit:FacilityName"]').value = facility.facilityName || '';
            editFacilityForm.querySelector('[data-facility-input="edit:Description"]').value = facility.description || '';
            editFacilityForm.querySelector('[data-facility-input="edit:Capacity"]').value = facility.capacity || '';
            editFacilityForm.querySelector('[data-facility-input="edit:AvailabilityStatus"]').value = facility.availabilityStatus || 'Available';
            editFacilityForm.querySelector('[data-facility-input="edit:ExistingImageUrl"]').value = facility.imageUrl || '';
            editFacilityForm.querySelector('[data-facility-input="edit:ImageFiles"]').value = '';
        }

        function resetAddFacilityForm() {
            addFacilityForm.reset();
            clearFacilityFieldErrors('add');
            clearModalAlert(addFacilityAlert);
        }

        function resetEditFacilityForm() {
            editFacilityForm.reset();
            clearFacilityFieldErrors('edit');
            clearModalAlert(editFacilityAlert);
        }

        async function submitFacilityForm(form, submitButton, url, prefix, successMessage, alertElement, closeTarget, refreshWork) {
            if (form.dataset.submitting === 'true') {
                return;
            }

            const originalMarkup = submitButton.innerHTML;
            form.dataset.submitting = 'true';
            submitButton.disabled = true;
            submitButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i><span>Saving...</span>';

            clearSectionAlert();
            clearFacilityFieldErrors(prefix);
            clearModalAlert(alertElement);

            try {
                const formData = new FormData(form);
                formData.append('__RequestVerificationToken', token);

                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                    body: formData
                });

                const contentType = response.headers.get('content-type') || '';
                const payload = contentType.includes('application/json')
                    ? await response.json()
                    : { success: false, message: 'Unexpected server response.' };

                if (!response.ok || !payload || payload.success === false) {
                    applyFacilityErrors(prefix, payload);
                    showModalAlert(alertElement, 'error', payload?.message || 'Unable to save facility.');
                    return;
                }

                closeModal(closeTarget);
                if (prefix === 'add') {
                    resetAddFacilityForm();
                } else {
                    resetEditFacilityForm();
                }
                showSectionAlert('success', payload.message || successMessage);

                Promise.resolve(refreshWork())
                    .catch(function (error) {
                        console.error(error);
                        showSectionAlert('error', 'Facility saved, but the list could not be refreshed. Reload the page.');
                    });
            } catch (error) {
                console.error(error);
                showModalAlert(alertElement, 'error', 'Unable to save facility. Please try again.');
            } finally {
                delete form.dataset.submitting;
                submitButton.disabled = false;
                submitButton.innerHTML = originalMarkup;
            }
        }

        function fillReservationDetails(details) {
            document.getElementById('reservationDetailFacility').textContent = details.facility || '-';
            document.getElementById('reservationDetailHomeowner').textContent = details.homeowner || '-';
            document.getElementById('reservationDetailDate').textContent = details.reservationDate || '-';
            document.getElementById('reservationDetailTime').textContent = (details.startTime || '-') + ' - ' + (details.endTime || '-');
            document.getElementById('reservationDetailStatus').textContent = details.status || '-';
            document.getElementById('reservationDetailCreated').textContent = details.createdAt || '-';
            document.getElementById('reservationDetailPurpose').textContent = details.purpose || '-';
        }

        function fillFacilityDetails(button) {
            document.getElementById('facilityDetailName').textContent = button.getAttribute('data-facility-name') || '-';
            document.getElementById('facilityDetailStatus').textContent = button.getAttribute('data-facility-status') || '-';
            document.getElementById('facilityDetailCapacity').textContent = button.getAttribute('data-facility-capacity') || '-';
            document.getElementById('facilityDetailDescription').textContent = button.getAttribute('data-facility-description') || '-';

            const image = document.getElementById('facilityDetailImage');
            const fallback = document.getElementById('facilityDetailImageFallback');
            const imageUrl = button.getAttribute('data-facility-image') || '';

            if (imageUrl) {
                image.src = imageUrl;
                image.classList.remove('reservation-hidden');
                fallback.classList.add('reservation-hidden');
            } else {
                image.removeAttribute('src');
                image.classList.add('reservation-hidden');
                fallback.classList.remove('reservation-hidden');
            }
        }

        async function handleReservationAction(action, reservationId) {
            const url = action === 'approve' ? moduleRoot.dataset.approveUrl : moduleRoot.dataset.rejectUrl;
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                credentials: 'same-origin',
                body: new URLSearchParams({ reservationId: reservationId }).toString()
            });

            const payload = await response.json();
            if (!response.ok || !payload || payload.success === false) {
                throw new Error(payload?.message || 'Unable to update reservation.');
            }

            await Promise.all([refreshReservationsTable(), refreshSummary()]);
            showSectionAlert('success', payload.message || 'Reservation updated successfully.');
        }

        const handleModuleClick = function (event) {
            const editFacilityButton = event.target.closest('[data-edit-facility="true"]');
            if (editFacilityButton) {
                const editUrl = editFacilityButton.getAttribute('data-edit-url');
                if (!editUrl) {
                    showSectionAlert('error', 'Unable to load the selected facility.');
                    return;
                }

                clearSectionAlert();
                resetEditFacilityForm();
                fetch(editUrl, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                })
                    .then(async function (response) {
                        const payload = await response.json();
                        if (!response.ok || !payload || payload.success === false || !payload.facility) {
                            throw new Error(payload?.message || 'Unable to load the selected facility.');
                        }

                        populateEditFacilityForm(payload.facility);
                        showModal(editFacilityModal);
                    })
                    .catch(function (error) {
                        console.error(error);
                        showSectionAlert('error', error.message || 'Unable to load the selected facility.');
                    });
                return;
            }

            const viewFacilityButton = event.target.closest('[data-view-facility="true"]');
            if (viewFacilityButton) {
                clearSectionAlert();
                fillFacilityDetails(viewFacilityButton);
                showModal(facilityDetailsModal);
                return;
            }

            const deleteFacilityButton = event.target.closest('[data-delete-facility="true"]');
            if (deleteFacilityButton) {
                const facilityId = deleteFacilityButton.getAttribute('data-facility-id');
                const facilityName = deleteFacilityButton.getAttribute('data-facility-name') || 'this facility';
                if (!facilityId || !confirm('Delete ' + facilityName + '?')) {
                    return;
                }

                clearSectionAlert();
                fetch(moduleRoot.dataset.deleteFacilityUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    credentials: 'same-origin',
                    body: buildFormBody({ facilityId: facilityId })
                })
                    .then(async function (response) {
                        const payload = await response.json();
                        if (!response.ok || !payload || payload.success === false) {
                            throw new Error(payload?.message || 'Unable to delete the facility.');
                        }

                        await refreshFacilitiesModule();
                        showSectionAlert('success', payload.message || 'Facility deleted successfully.');
                    })
                    .catch(function (error) {
                        console.error(error);
                        showSectionAlert('error', error.message || 'Unable to delete the facility.');
                    });
                return;
            }

            const reservationActionButton = event.target.closest('[data-reservation-action]');
            if (reservationActionButton) {
                const action = reservationActionButton.getAttribute('data-reservation-action');
                const reservationId = reservationActionButton.getAttribute('data-reservation-id');
                if (!action || !reservationId) {
                    return;
                }

                clearSectionAlert();
                handleReservationAction(action, reservationId).catch(function (error) {
                    console.error(error);
                    showSectionAlert('error', error.message || 'Unable to update the reservation.');
                });
                return;
            }

            const viewReservationButton = event.target.closest('[data-view-reservation="true"]');
            if (viewReservationButton) {
                const detailsUrl = viewReservationButton.getAttribute('data-details-url');
                if (!detailsUrl) {
                    showSectionAlert('error', 'Unable to load reservation details.');
                    return;
                }

                fetch(detailsUrl, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin'
                })
                    .then(async function (response) {
                        const payload = await response.json();
                        if (!response.ok || !payload || payload.success === false || !payload.reservation) {
                            throw new Error(payload?.message || 'Unable to load reservation details.');
                        }

                        fillReservationDetails(payload.reservation);
                        showModal(detailsModal);
                    })
                    .catch(function (error) {
                        console.error(error);
                        showSectionAlert('error', error.message || 'Unable to load reservation details.');
                    });
            }
        };

        const handleBackdropClick = function (event) {
            if (event.target.classList.contains('reservation-modal')) {
                closeModal(event.target);
            }
        };

        const handleDocumentClick = function (event) {
            const closeButton = event.target.closest('[data-reservation-close]');
            if (!closeButton) {
                return;
            }

            const matchingModal = reservationModals.find(function (modal) {
                return modal.contains(closeButton);
            });

            if (!matchingModal) {
                return;
            }

            event.preventDefault();
            event.stopPropagation();
            closeModal(matchingModal);
        };

        const handleKeydown = function (event) {
            if (event.key === 'Escape') {
                [addFacilityModal, editFacilityModal, detailsModal, facilityDetailsModal, reportModal].forEach(closeModal);
            }
        };

        const handleReportDownload = function () {
            const params = new URLSearchParams(new FormData(reportForm));
            window.open(moduleRoot.dataset.reportUrl + '?' + params.toString(), '_blank', 'noopener');
            closeModal(reportModal);
            showSectionAlert('success', 'Reservation report opened in a new tab.');
        };

        openAddFacilityButton.addEventListener('click', function () {
            resetAddFacilityForm();
            showModal(addFacilityModal);
        });

        openReportButton.addEventListener('click', function () {
            showModal(reportModal);
        });

        submitAddFacilityButton.addEventListener('click', function () {
            submitFacilityForm(
                addFacilityForm,
                submitAddFacilityButton,
                moduleRoot.dataset.addFacilityUrl,
                'add',
                'Facility added successfully.',
                addFacilityAlert,
                addFacilityModal,
                refreshFacilitiesModule
            );
        });

        submitEditFacilityButton.addEventListener('click', function () {
            submitFacilityForm(
                editFacilityForm,
                submitEditFacilityButton,
                moduleRoot.dataset.editFacilityUrl,
                'edit',
                'Facility updated successfully.',
                editFacilityAlert,
                editFacilityModal,
                refreshFacilitiesModule
            );
        });

        generateReportButton.addEventListener('click', handleReportDownload);
        moduleRoot.addEventListener('click', handleModuleClick);
        document.addEventListener('click', handleDocumentClick);
        reservationModals.forEach(function (modal) {
            modal.addEventListener('click', handleBackdropClick);
        });
        document.addEventListener('keydown', handleKeydown);

        const reservationManagementCleanup = function () {
            moduleRoot.removeEventListener('click', handleModuleClick);
            generateReportButton.removeEventListener('click', handleReportDownload);
            document.removeEventListener('click', handleDocumentClick);
            document.removeEventListener('keydown', handleKeydown);
            reservationModals.forEach(function (modal) {
                modal.removeEventListener('click', handleBackdropClick);
                closeModal(modal);
                if (modal.parentElement === document.body) {
                    modal.remove();
                }
            });
            window.__reservationManagementCleanup = null;
        };

        window.__reservationManagementCleanup = reservationManagementCleanup;
        if (typeof window.__registerAdminEmbeddedCleanup === 'function') {
            window.__registerAdminEmbeddedCleanup(reservationManagementCleanup);
        }

        requestAnimationFrame(function () {
            refreshReservationModule();
        });
    })();
</script>
