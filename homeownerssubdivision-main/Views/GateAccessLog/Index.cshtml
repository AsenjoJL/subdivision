@model HOMEOWNER.Models.ViewModels.AdminGateAccessLogViewModel

<section class="admin-gate-module" data-admin-gate-module>
    <div class="admin-gate-shell">
        <header class="admin-gate-hero">
            <div>
                <h2>Gate access logs</h2>
                <p>Track who entered or exited the subdivision, validate visitor movement, and review recent gate activity with clear filters.</p>
            </div>
            <div class="admin-gate-meta">
                <span class="admin-gate-chip">
                    <i class="fas fa-arrow-right-to-bracket"></i>
                    <span><strong>@Model.Statistics.TotalEntries</strong> entries</span>
                </span>
                <span class="admin-gate-chip">
                    <i class="fas fa-arrow-right-from-bracket"></i>
                    <span><strong>@Model.Statistics.TotalExits</strong> exits</span>
                </span>
                <span class="admin-gate-chip is-accent">
                    <i class="fas fa-id-card"></i>
                    <span><strong>@Model.Logs.Count</strong> logs in range</span>
                </span>
            </div>
        </header>

        <section class="admin-gate-stat-grid">
            <article class="admin-gate-stat-card">
                <span>Homeowner entries</span>
                <strong>@Model.Statistics.HomeownerEntries</strong>
            </article>
            <article class="admin-gate-stat-card">
                <span>Visitor entries</span>
                <strong>@Model.Statistics.VisitorEntries</strong>
            </article>
            <article class="admin-gate-stat-card">
                <span>Staff entries</span>
                <strong>@Model.Statistics.StaffEntries</strong>
            </article>
            <article class="admin-gate-stat-card">
                <span>Delivery entries</span>
                <strong>@Model.Statistics.DeliveryEntries</strong>
            </article>
        </section>

        <section class="admin-gate-toolbar"
                 data-admin-gate-toolbar
                 data-load-url="@Url.Action("Index", "GateAccessLog")">
            <label class="admin-gate-search">
                <i class="fas fa-search"></i>
                <input type="search" placeholder="Search names, gates, plate numbers, or guards" value="@Model.SearchQuery" data-admin-gate-search />
            </label>
            <label class="admin-gate-field">
                <span>User type</span>
                <select data-admin-gate-user-type>
                    <option value="">All user types</option>
                    @foreach (var item in Model.UserTypes)
                    {
                        <option value="@item" selected="@(Model.SelectedUserType == item)">@item</option>
                    }
                </select>
            </label>
            <label class="admin-gate-field">
                <span>Access type</span>
                <select data-admin-gate-access-type>
                    <option value="">All access types</option>
                    @foreach (var item in Model.AccessTypes)
                    {
                        <option value="@item" selected="@(Model.SelectedAccessType == item)">@item</option>
                    }
                </select>
            </label>
            <label class="admin-gate-field">
                <span>Start date</span>
                <input type="date" value="@Model.StartDate.ToString("yyyy-MM-dd")" data-admin-gate-start-date />
            </label>
            <label class="admin-gate-field">
                <span>End date</span>
                <input type="date" value="@Model.EndDate.ToString("yyyy-MM-dd")" data-admin-gate-end-date />
            </label>
            <div class="admin-gate-actions">
                <button type="button" class="admin-gate-button secondary" data-admin-gate-reset>Reset</button>
                <button type="button" class="admin-gate-button" data-admin-gate-apply>
                    <i class="fas fa-filter"></i>
                    <span>Apply filters</span>
                </button>
            </div>
        </section>

        <div class="admin-gate-alert admin-gate-hidden" data-admin-gate-error>
            <i class="fas fa-circle-exclamation"></i>
            <span>Unable to load gate access logs.</span>
        </div>

        <div class="admin-gate-list">
            @if (Model.Logs.Any())
            {
                @foreach (var log in Model.Logs)
                {
                    var userTone = log.UserType.ToLowerInvariant() switch
                    {
                        "homeowner" => "is-homeowner",
                        "visitor" => "is-visitor",
                        "staff" => "is-staff",
                        "delivery" => "is-delivery",
                        _ => string.Empty
                    };
                    var accessTone = string.Equals(log.AccessType, "Entry", StringComparison.OrdinalIgnoreCase) ? "is-entry" : "is-exit";

                    <article class="admin-gate-card"
                             data-admin-gate-card
                             data-log-name="@log.DisplayName"
                             data-log-user="@log.UserType"
                             data-log-access="@log.AccessType"
                             data-log-time="@log.AccessTime.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")"
                             data-log-plate="@(log.PlateNumber ?? "N/A")"
                             data-log-gate="@(log.GateLocation ?? "Not specified")"
                             data-log-verified="@(log.VerifiedBy ?? "Not recorded")"
                             data-log-notes="@(log.Notes ?? "No notes provided.")">
                        <div class="admin-gate-card__header">
                            <div>
                                <div class="admin-gate-card__title">@log.DisplayName</div>
                                <div class="admin-gate-card__meta">@log.AccessTime.ToLocalTime().ToString("MMM dd, yyyy · hh:mm tt")</div>
                            </div>
                            <div class="admin-gate-card__badges">
                                <span class="admin-gate-pill @userTone">@log.UserType</span>
                                <span class="admin-gate-pill @accessTone">@log.AccessType</span>
                            </div>
                        </div>
                        <div class="admin-gate-card__grid">
                            <div>
                                <span class="admin-gate-card__label">Gate</span>
                                <strong>@(log.GateLocation ?? "Not specified")</strong>
                            </div>
                            <div>
                                <span class="admin-gate-card__label">Plate number</span>
                                <strong>@(string.IsNullOrWhiteSpace(log.PlateNumber) ? "N/A" : log.PlateNumber)</strong>
                            </div>
                            <div>
                                <span class="admin-gate-card__label">Verified by</span>
                                <strong>@(string.IsNullOrWhiteSpace(log.VerifiedBy) ? "Not recorded" : log.VerifiedBy)</strong>
                            </div>
                        </div>
                        <div class="admin-gate-card__footer">
                            <span class="admin-gate-card__hint">Log #@log.LogID</span>
                            <button type="button" class="admin-gate-button secondary" data-admin-gate-view>
                                <i class="fas fa-eye"></i>
                                <span>View details</span>
                            </button>
                        </div>
                    </article>
                }
            }
            else
            {
                <div class="admin-gate-empty">
                    <i class="fas fa-door-open"></i>
                    <h3>No logs found</h3>
                    <p>Try widening the date range or clearing the filters.</p>
                </div>
            }
        </div>
    </div>

    <div class="admin-gate-modal admin-gate-hidden" data-admin-gate-modal hidden>
        <div class="admin-gate-modal-backdrop" data-admin-gate-close></div>
        <section class="admin-gate-modal-card" role="dialog" aria-modal="true" aria-labelledby="adminGateModalTitle">
            <div class="admin-gate-modal-header">
                <div>
                    <p class="admin-gate-modal-eyebrow">Details</p>
                    <h3 id="adminGateModalTitle">Gate access entry</h3>
                </div>
                <button type="button" class="admin-gate-modal-close" data-admin-gate-close aria-label="Close gate access details">
                    <i class="fas fa-xmark"></i>
                </button>
            </div>
            <div class="admin-gate-modal-body">
                <div class="admin-gate-detail-grid">
                    <div><span>Name</span><strong data-admin-gate-detail="name"></strong></div>
                    <div><span>User type</span><strong data-admin-gate-detail="user"></strong></div>
                    <div><span>Access type</span><strong data-admin-gate-detail="access"></strong></div>
                    <div><span>Access time</span><strong data-admin-gate-detail="time"></strong></div>
                    <div><span>Plate number</span><strong data-admin-gate-detail="plate"></strong></div>
                    <div><span>Gate</span><strong data-admin-gate-detail="gate"></strong></div>
                    <div><span>Verified by</span><strong data-admin-gate-detail="verified"></strong></div>
                </div>
                <div class="admin-gate-detail-notes">
                    <span>Notes</span>
                    <p data-admin-gate-detail="notes"></p>
                </div>
            </div>
            <div class="admin-gate-modal-footer">
                <button type="button" class="admin-gate-button secondary" data-admin-gate-close>Close</button>
            </div>
        </section>
    </div>

    <script>
        (function () {
            const root = document.currentScript?.closest('[data-admin-gate-module]');
            if (root && typeof window.initializeAdminGateAccessModule === 'function') {
                window.initializeAdminGateAccessModule(root);
            }
        })();
    </script>
</section>
